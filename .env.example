# === Supabase (Project Settings → API) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secrète — serveur uniquement, ne JAMAIS exposer au client ni committer
SUPABASE_SERVICE_ROLE_KEY=

# === Chiffrement des clés API Vendus (AES-256-GCM) ===
# Générer : openssl rand -base64 32
MESA_ENCRYPTION_KEY=

# === Vendus (base API) ===
VENDUS_API_BASE=https://www.vendus.pt/ws/v1.1
